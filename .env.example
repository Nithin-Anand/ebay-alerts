# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by pydantic-settings.

# ── eBay Developer credentials ────────────────────────────────────────────────
# Register at https://developer.ebay.com → My Account → Application Keys
# Create a "Production" key set. Copy the App ID (Client ID) and Cert ID (Client Secret).
EBAY_CLIENT_ID=YourApp-YourApp-PRD-xxxxxxxx-xxxxxxxx
EBAY_CLIENT_SECRET=PRD-xxxxxxxxxxxxxxxx-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Pushover credentials ──────────────────────────────────────────────────────
# App token: https://pushover.net/apps/build — create a new application
# User key:  https://pushover.net — your user/group key on the dashboard
PUSHOVER_TOKEN=azGDORePK8gMaC0QOYAMyEEuzJnyUi
PUSHOVER_USER=uQiRzpo4DXghDmr9QzzfQu

# ── Ollama ───────────────────────────────────────────────────────────────────
# URL of your Ollama instance. Inside Docker Compose on Linux, use:
#   http://host.docker.internal:11434
# or the hostname of a dedicated Ollama container/service.
OLLAMA_URL=http://host.docker.internal:11434

# Default Ollama model. Override per-search with the llm.model field in searches.yaml.
# Text models: llama3.2, mistral, qwen2.5
# Vision models (for future image analysis): llava, qwen2-vl, llava-phi3
OLLAMA_MODEL=llama3.2

# ── Web UI ───────────────────────────────────────────────────────────────────
# Monitoring/editing interface. No authentication — keep it off the internet.
# The docker-compose.yml port mapping controls outside exposure; these control
# the bind inside the container (or locally).
# WEB_HOST=0.0.0.0
# WEB_PORT=8787

# ── Paths (override when running locally outside Docker) ──────────────────────
# SEARCHES_FILE=./searches.yaml
# DATA_DIR=./data

# ── Auto-archiving of ended listings ─────────────────────────────────────────
# Periodically verifies stored hits against eBay (batched 20 per API call) and
# moves ended/removed listings to the Archive tab. Set PRUNE_ENABLED=false to
# turn it off. INTERVAL is seconds between sweeps; BATCH_SIZE caps how many hits
# are verified per sweep so a large history drains gradually.
# PRUNE_ENABLED=true
# PRUNE_INTERVAL_SECONDS=3600
# PRUNE_BATCH_SIZE=200

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
